# Required
SECRET_KEY=change-me-to-a-random-string

# Database — PostgreSQL for production, SQLite for dev:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/smg
#   DATABASE_URL=sqlite:///data/app.db
# If empty → SQLite at data/app.db
DATABASE_URL=

# Email (magic links) via SMTP — works with any provider:
#
# AWS SES:    SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
# Resend:     SMTP_HOST=smtp.resend.com
# Mailgun:    SMTP_HOST=smtp.mailgun.org
# SendGrid:   SMTP_HOST=smtp.sendgrid.net
#
# If SMTP_HOST is not set → dev mode (magic links printed to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=login@yourdomain.com

# Webhook authentication (pick one or both):
#   Bearer token:   WEBHOOK_SECRET=your-secret
#   HMAC signature: WEBHOOK_HMAC_SECRET=your-hmac-secret (for GateFlow, Stripe-style)
WEBHOOK_SECRET=
WEBHOOK_HMAC_SECRET=

# Product-to-credits mapping (JSON). Webhook with {"product": "100-credits"}
# will add 100 credits. Any product slug/id not listed here requires explicit "credits" field.
CREDIT_PRODUCTS={"100-credits": 100, "500-credits": 500, "unlimited": 10000}

# App
BASE_URL=http://localhost:8000
