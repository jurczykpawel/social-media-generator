# Required
SECRET_KEY=change-me-to-a-random-string

# Email (magic links) — pick ONE provider:
#
# Option 1: AWS SES (set region + configure AWS credentials via env or ~/.aws)
# AWS_SES_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
#
# Option 2: Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx
#
# If neither is set → dev mode (magic links printed to console)
EMAIL_FROM=login@yourdomain.com

# Webhook secret for external payment provider (GateFlow) to add credits
WEBHOOK_SECRET=change-me-to-a-random-string

# App
BASE_URL=http://localhost:8000
